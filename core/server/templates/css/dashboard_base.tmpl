{{define "dashboard_base_css"}}
<style>
/* ==========================================================================
   pb-ext Dashboard Base CSS
   Supplements PocketBase v0.38 CSS with custom components PB doesn't provide.
   PB CSS is piggybacked at runtime; only define what's truly missing.
   ========================================================================== */

/* ---------------------------------------------------------------------------
   Gap aliases — templates use these; PB provides .gap-5/10/15/20/25/30/sm/base
   --------------------------------------------------------------------------- */
.gap-xs, .gap-small   { gap: 5px !important; }
.flex-gap-10           { gap: 10px !important; }
.flex-gap-20           { gap: 20px !important; }

/* ---------------------------------------------------------------------------
   Card — PB v0.38 has no card component
   --------------------------------------------------------------------------- */
.card {
    background: var(--surfaceColor);
    border-radius: var(--lgBorderRadius, 8px);
    box-shadow: 0 0 0 1px var(--surfaceAlt4Color, rgba(0,0,0,.08));
    overflow: hidden;
}
.card-body {
    padding: 15px;
}
.card-body > .grid {
    margin-left: 0;
    margin-right: 0;
    padding: 0 2px;
}
.card-sm {
    background: var(--surfaceColor);
    border-radius: var(--borderRadius, 4px);
    padding: 10px;
}
.view-card {
    background: var(--surfaceColor);
    border-radius: var(--lgBorderRadius, 8px);
    box-shadow: 0 0 0 1px var(--surfaceAlt4Color, rgba(0,0,0,.08));
    padding: 10px;
}

/* ---------------------------------------------------------------------------
   Progress bar — PB v0.38 has no progress bar
   --------------------------------------------------------------------------- */
.progress {
    height: 6px;
    background: var(--surfaceAlt3Color, rgba(0,0,0,.1));
    border-radius: 3px;
    overflow: hidden;
}
.progress-bar {
    height: 100%;
    border-radius: 3px;
    transition: width 0.3s ease;
}
.progress-bar.primary   { background: var(--accentColor, var(--primaryColor, #5b8def)); }
.progress-bar.success   { background: var(--successColor, #33b56f); }
.progress-bar.warning   { background: var(--warningColor, #eca53a); }
.progress-bar.danger    { background: var(--dangerColor, #d44040); }

/* ---------------------------------------------------------------------------
   Badge — distinct from PB's .label; used across dashboard and API views
   --------------------------------------------------------------------------- */
.badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--smFontSize, 12px);
    font-weight: 500;
    padding: 2px 8px;
    border-radius: var(--borderRadius, 4px);
    white-space: nowrap;
}
.badge-sm {
    font-size: 11px;
    padding: 1px 6px;
}
.badge-success, .badge.success   { background: var(--surfaceSuccessColor, rgba(51,181,111,.15)); color: var(--successColor, #33b56f); }
.badge-danger,  .badge.danger    { background: var(--surfaceDangerColor, rgba(212,64,64,.15));   color: var(--dangerColor, #d44040); }
.badge-primary, .badge.primary   { background: var(--surfaceAlt2Color, rgba(91,141,239,.15));    color: var(--accentColor, #5b8def); }

/* ---------------------------------------------------------------------------
   Button modifiers PB v0.38 lacks
   --------------------------------------------------------------------------- */
.btn-xs {
    min-height: 24px;
    padding: 2px 10px;
    font-size: 11px;
}
.btn-block {
    display: flex !important;
    width: 100%;
}

/* ---------------------------------------------------------------------------
   Form fields — PB v0.38 uses .field; our templates use .form-field/.form-control
   --------------------------------------------------------------------------- */
.form-field {
    margin-bottom: 10px;
}
.form-label {
    display: block;
    font-size: var(--smFontSize, 12px);
    font-weight: 600;
    color: var(--surfaceTxtHintColor);
    margin-bottom: 4px;
}
.form-control {
    width: 100%;
    min-height: var(--btnHeight, 38px);
    padding: var(--inputPadding, 10px);
    border: 1px solid var(--inputBorderColor, rgba(0,0,0,.15));
    border-radius: var(--inputBorderRadius, 4px);
    background: var(--inputColor);
    color: var(--surfaceTxtColor);
    font-size: var(--fontSize, 14px);
    font-family: var(--baseFontFamily);
    outline: none;
    transition: border-color var(--animationSpeed, 0.15s);
}
.form-control:focus {
    border-color: var(--inputFocusColor, #5b8def);
}
.form-control-sm {
    min-height: 30px;
    padding: 4px 8px;
    font-size: 12px;
}
.field-input {
    width: 100%;
    min-height: var(--btnHeight, 38px);
    padding: var(--inputPadding, 10px);
    border: 1px solid var(--inputBorderColor, rgba(0,0,0,.15));
    border-radius: var(--inputBorderRadius, 4px);
    background: var(--inputColor);
    color: var(--surfaceTxtColor);
    font-size: var(--fontSize, 14px);
    outline: none;
}

/* ---------------------------------------------------------------------------
   Table — PB v0.38 styles raw table elements; we use .table for scoping
   --------------------------------------------------------------------------- */
.table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--smFontSize, 13px);
}
.table th {
    text-align: left;
    font-weight: 600;
    color: var(--surfaceTxtHintColor);
    padding: 8px 10px;
    border-bottom: 2px solid var(--surfaceAlt3Color, rgba(0,0,0,.1));
}
.table td {
    padding: 8px 10px;
    border-bottom: 1px solid var(--surfaceAlt3Color, rgba(0,0,0,.05));
    vertical-align: middle;
}
.table-compact th,
.table-compact td {
    padding: 4px 8px;
    font-size: 12px;
}
.table-wrapper {
    overflow-x: auto;
}

/* ---------------------------------------------------------------------------
   Section — our section pattern (PB uses .section-heading differently)
   --------------------------------------------------------------------------- */
.section {
    margin-bottom: var(--spacing, 15px);
}
.section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--spacing, 15px);
}
.section-title {
    font-size: var(--fontSize, 14px);
    font-weight: 600;
    color: var(--surfaceTxtColor);
    margin: 0;
}

/* ---------------------------------------------------------------------------
   Overlay / Popup — PB uses .modal with ::before; we use .overlay/.popup
   --------------------------------------------------------------------------- */
.overlay {
    position: fixed;
    inset: 0;
    background: var(--modalOverlayColor, rgba(0,0,0,.45));
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}
.popup {
    background: var(--surfaceColor);
    border-radius: 8px;
    box-shadow: 0 10px 40px rgba(0,0,0,.2);
    max-width: 90vw;
    max-height: 90vh;
    overflow: hidden;
    position: relative;
}
.popup-lg {
    max-width: 800px;
    width: 95%;
}
.popup-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 20px;
    border-bottom: 1px solid var(--surfaceAlt3Color, rgba(0,0,0,.1));
}
.popup-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: var(--surfaceTxtColor);
}
.popup-close-btn {
    cursor: pointer;
    background: none;
    border: none;
    font-size: 18px;
    color: var(--surfaceTxtHintColor);
    padding: 4px;
}
.popup-close-btn:hover {
    color: var(--surfaceTxtColor);
}
.popup-content {
    padding: 15px 20px;
    overflow-y: auto;
}
.popup-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    padding: 15px 20px;
    border-top: 1px solid var(--surfaceAlt3Color, rgba(0,0,0,.1));
}

/* ---------------------------------------------------------------------------
   Inline code
   --------------------------------------------------------------------------- */
.code {
    font-family: var(--baseFontFamily, monospace);
    background: var(--surfaceAlt1Color);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
}

/* ---------------------------------------------------------------------------
   Animation
   --------------------------------------------------------------------------- */
.animate-spin {
    animation: spin 1s linear infinite;
}
@keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}

/* ==========================================================================
   Dashboard layout — entirely our own structural classes
   ========================================================================== */
.app-layout {
    display: flex;
    min-height: 100vh;
}

.app-sidebar {
    width: 56px;
    background: var(--surfaceColor);
    border-right: 1px solid var(--surfaceAlt3Color, rgba(0,0,0,.08));
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 0;
    gap: 5px;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
}

.app-sidebar .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
}

.main-menu {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
}

.menu-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--borderRadius, 4px);
    color: var(--surfaceTxtHintColor);
    cursor: pointer;
    transition: background var(--animationSpeed, 0.15s), color var(--animationSpeed, 0.15s);
    text-decoration: none;
    font-size: 18px;
}
.menu-item:hover {
    background: var(--surfaceAlt2Color, rgba(0,0,0,.05));
    color: var(--surfaceTxtColor);
}
.menu-item.current-route,
.menu-item.active {
    background: var(--surfaceAlt2Color, rgba(0,0,0,.05));
    color: var(--accentColor, #5b8def);
}

.app-body {
    margin-left: 56px;
    flex: 1;
    min-width: 0;
}

.section-content {
    min-height: 100vh;
}

.dashboard-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
}

.panels-grid {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}
.panels-grid > * {
    flex: 1;
    min-width: 280px;
}

/* ---------------------------------------------------------------------------
   Misc utilities
   --------------------------------------------------------------------------- */
.link-hint {
    opacity: 0.6;
    transition: opacity 0.2s;
}
.link-hint:hover {
    opacity: 1;
}

.thumb-circle {
    border-radius: 50%;
}

/* ---------------------------------------------------------------------------
   Responsive grid — PB v0.38 uses .col-* with container queries, but our
   templates use the .grid-N pattern on the container itself. These thin
   overrides make all direct children fill equally.
   --------------------------------------------------------------------------- */
.grid-2 > *  { width: calc(50%   - var(--gridGap, var(--spacing))); }
.grid-3 > *  { width: calc(33.333% - var(--gridGap, var(--spacing))); }
.grid-4 > *  { width: calc(25%   - var(--gridGap, var(--spacing))); }
.grid-sm-1 > * { width: calc(100%  - var(--gridGap, var(--spacing))); }
.grid-sm-2 > * { width: calc(50%   - var(--gridGap, var(--spacing))); }
.grid-sm-3 > * { width: calc(33.333% - var(--gridGap, var(--spacing))); }
.grid-sm-5 > * { width: calc(20%   - var(--gridGap, var(--spacing))); }
.grid-xl-2 > * { width: calc(50%   - var(--gridGap, var(--spacing))); }
.grid-xl-3 > * { width: calc(33.333% - var(--gridGap, var(--spacing))); }
.grid-xl-4 > * { width: calc(25%   - var(--gridGap, var(--spacing))); }
.grid-xl-5 > * { width: calc(20%   - var(--gridGap, var(--spacing))); }
.grid-xl-6 > * { width: calc(16.666% - var(--gridGap, var(--spacing))); }
@media (max-width: 767px) {
    .grid-xl-2 > *, .grid-xl-3 > *, .grid-xl-4 > *, .grid-xl-5 > *, .grid-xl-6 > *,
    .grid-sm-2 > *, .grid-sm-3 > *, .grid-sm-5 > * { width: calc(100% - var(--gridGap, var(--spacing))); }
}
@media (min-width: 768px) and (max-width: 1199px) {
    .grid-xl-3 > *, .grid-xl-4 > *, .grid-xl-5 > *, .grid-xl-6 > * { width: calc(50% - var(--gridGap, var(--spacing))); }
}

/* pb-piggybacked-only — elements shown only when PB CSS loaded */
.pb-piggybacked-only {
    display: none;
}
.pb-styled .pb-piggybacked-only {
    display: inline-flex;
}
</style>
{{end}}
