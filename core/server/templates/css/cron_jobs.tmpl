{{define "cron_jobs_css"}}
<style>
/* =============================================================================
   CRON JOBS MANAGEMENT CSS
   Extends dashboard_base_css — popup, animate-spin, @keyframes spin are defined
   in the base template and must NOT be duplicated here.
   ============================================================================= */

/* ---------------------------------------------------------------------------
   Cron-specific custom properties
   --------------------------------------------------------------------------- */
:root {
    --cron-border-radius: 6px;
    --cron-transition: all 0.15s ease-in-out;
}

/* =============================================================================
   CONTAINER & LAYOUT
   ============================================================================= */

.cron-jobs-container {
    background: var(--surfaceColor);
    border-radius: var(--cron-border-radius);
    overflow: hidden;
}

.cron-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 3rem 2rem;
    color: var(--surfaceTxtHintColor);
    font-size: 14px;
}

.cron-loading i {
    font-size: 20px;
}

.cron-empty {
    text-align: center;
    padding: 3rem 2rem;
}

.cron-empty i {
    font-size: 3rem;
    color: var(--surfaceTxtHintColor);
    margin-bottom: 1rem;
}

/* =============================================================================
   TABLE STYLING — extends .table from dashboard_base_css
   ============================================================================= */

.cron-jobs-container .table {
    table-layout: auto;
}

/* Job name styling */
.cron-job-name {
    font-weight: 600;
    color: var(--surfaceTxtColor);
    display: block;
    margin-bottom: 6px;
    font-size: 14px;
}

/* Job description */
.cron-job-description {
    font-size: 11px;
    color: var(--surfaceTxtHintColor);
    opacity: 0.7;
    line-height: 1.4;
    margin-top: 3px;
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* Job type badges */
.cron-job-type {
    display: inline-block;
    padding: 1px 4px;
    border-radius: 3px;
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-top: 2px;
    vertical-align: top;
}

.cron-job-type.system {
    background: var(--surfaceWarningColor, rgba(236, 165, 58, 0.1));
    color: var(--warningColor, #eca53a);
    border: 1px solid var(--surfaceWarningColor, rgba(236, 165, 58, 0.2));
}

.cron-job-type.user {
    background: var(--surfaceSuccessColor, rgba(51, 181, 111, 0.1));
    color: var(--successColor, #33b56f);
    border: 1px solid var(--surfaceSuccessColor, rgba(51, 181, 111, 0.2));
}

/* Schedule column styling */
.cron-expression {
    background: var(--surfaceAlt1Color);
    padding: 2px 5px;
    border-radius: 3px;
    font-size: 11px;
    font-family: var(--baseFontFamily);
    color: var(--surfaceTxtColor);
    display: inline-block;
    margin-bottom: 4px;
    font-weight: 500;
}

.cron-description {
    font-size: 10px;
    color: var(--surfaceTxtHintColor);
    opacity: 0.75;
    display: block;
    line-height: 1.3;
    font-weight: 500;
}

/* Column widths */
.cron-jobs-container .table td:first-child {
    min-width: 200px;
    width: 40%;
    padding-right: 20px;
}

.cron-jobs-container .table td:nth-child(2) {
    width: 80px;
    text-align: center;
    white-space: nowrap;
    padding: 0 8px;
}

.cron-jobs-container .table td:last-child {
    white-space: nowrap;
    width: 1%;
    text-align: right;
}

/* Button spacing */
.cron-jobs-container .table td:last-child .btn {
    margin-right: 4px;
}

.cron-jobs-container .table td:last-child .btn:last-child {
    margin-right: 0;
}

/* =============================================================================
   JOB DETAILS
   ============================================================================= */

.cron-job-details {
    color: var(--surfaceTxtColor);
}

.cron-job-details__section {
    margin-bottom: 24px;
}

.cron-job-details__section:last-child {
    margin-bottom: 0;
}

.cron-job-details__section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--surfaceAlt3Color);
    color: var(--surfaceTxtColor);
}

.cron-job-details__section-header i {
    color: var(--accentColor, var(--primaryColor, #5b8def));
}

/* =============================================================================
   CRON LOGS
   ============================================================================= */

.cron-logs {
    max-height: 300px;
    overflow-y: auto;
    border: 1px solid var(--surfaceAlt3Color);
    border-radius: var(--cron-border-radius);
}

.cron-log-entry {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    border-bottom: 1px solid var(--surfaceAlt3Color);
    font-size: 13px;
    transition: var(--cron-transition);
    cursor: default;
}

.cron-log-entry:last-child {
    border-bottom: none;
}

.cron-log-entry.has-details {
    cursor: pointer;
}

.cron-log-entry:hover {
    background: var(--surfaceAlt1Color);
}

.cron-log-entry--success {
    border-left: 3px solid var(--successColor);
}

.cron-log-entry--error {
    border-left: 3px solid var(--dangerColor);
}

.cron-log-entry__timestamp {
    color: var(--surfaceTxtHintColor);
    font-size: 12px;
    min-width: 140px;
}

.cron-log-entry__status {
    display: flex;
    align-items: center;
    width: 20px;
}

.cron-log-entry--success .cron-log-entry__status {
    color: var(--successColor);
}

.cron-log-entry--error .cron-log-entry__status {
    color: var(--dangerColor);
}

.cron-log-entry__message {
    flex: 1;
    color: var(--surfaceTxtColor);
}

.cron-log-entry.has-details {
    position: relative;
    padding-right: 32px;
}

.cron-log-entry.has-details::after {
    content: '\25B6';
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--surfaceTxtHintColor);
    font-size: 10px;
    transition: all 0.2s ease;
}

.cron-log-entry.has-details:hover::after {
    color: var(--accentColor, var(--primaryColor, #5b8def));
}

.cron-log-entry.has-details.expanded::after {
    content: '\25BC';
    transform: translateY(-50%);
}

.cron-log-entry.expanded {
    background: var(--surfaceAlt1Color);
    border-left-width: 4px;
}

.cron-log-entry .log-details {
    display: none;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--surfaceAlt3Color);
}

.cron-log-entry.expanded .log-details {
    display: block !important;
}

.cron-log-entry .log-details pre {
    margin: 4px 0 0 0;
    max-height: 200px;
    overflow-y: auto;
    font-family: var(--baseFontFamily);
    font-size: 11px;
    line-height: 1.4;
    cursor: text;
    user-select: text;
    -webkit-user-select: text;
    -moz-user-select: text;
    -ms-user-select: text;
}

.cron-log-entry .log-details pre:hover {
    background: var(--surfaceAlt3Color) !important;
    transition: background-color 0.15s ease;
}

.cron-log-entry .log-details pre::selection {
    background: var(--accentColor, var(--primaryColor, #5b8def));
    color: var(--surfaceColor);
}

.cron-log-entry .log-details pre::-moz-selection {
    background: var(--accentColor, var(--primaryColor, #5b8def));
    color: var(--surfaceColor);
}

.cron-logs-pagination {
    background: var(--surfaceAlt1Color);
    border-top: 1px solid var(--surfaceAlt3Color);
    border-radius: 0 0 var(--cron-border-radius) var(--cron-border-radius);
}

.cron-logs-pagination .btn {
    min-width: 28px;
    height: 24px;
    font-size: 11px;
    padding: 0 6px;
}

.cron-logs-pagination .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

/* =============================================================================
   ACCESSIBILITY & RESPONSIVE
   ============================================================================= */

@media (prefers-reduced-motion: reduce) {
    * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }

    .cron-loading i.animate-spin {
        animation: none;
    }
}
</style>
{{end}}
