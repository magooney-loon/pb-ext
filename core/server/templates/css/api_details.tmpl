{{define "api_details_css"}}
<style>
/* =============================================================================
   API DOCUMENTATION SYSTEM STYLES
   ============================================================================= */

/* =============================================================================
   LAYOUT & CONTAINERS
   ============================================================================= */

.api-details-container {
    display: flex;
    position: relative;
    min-height: 600px;
}

.api-main-content {
    flex: 1;
    min-width: 0;
    margin-top: 9px;
}

/* =============================================================================
   ENDPOINT LIST
   ============================================================================= */

.api-endpoint {
    margin-bottom: 8px;
    border: 1px solid var(--surfaceAlt3Color);
    border-radius: 6px;
    overflow: hidden;
}

.api-endpoint-header {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: var(--surfaceAlt1Color);
    cursor: pointer;
    transition: background-color 0.2s ease;
    gap: 12px;
}

.api-endpoint-header:hover {
    background: var(--surfaceAlt3Color);
}

.api-endpoint-content {
    padding: 0;
    max-height: 0;
    overflow: auto;
    transition: all 0.3s ease;
    background: var(--surfaceColor);
}

.api-endpoint-content.active {
    padding: 16px;
    max-height: 100vh;
    border-top: 1px solid var(--surfaceAlt3Color);
}

/* HTTP Method badges */
.http-method {
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: white;
    min-width: 50px;
    text-align: center;
}

.http-method.get,
.http-method.method-get {
    background: var(--infoColor, #2196f3);
}

.http-method.post,
.http-method.method-post {
    background: var(--successColor, #4caf50);
}

.http-method.put,
.http-method.method-put {
    background: var(--warningColor, #ff9800);
}

.http-method.patch,
.http-method.method-patch {
    background: var(--accentColor, #9c27b0);
}

.http-method.delete,
.http-method.method-delete {
    background: var(--dangerColor, #f44336);
}

.http-method.options {
    background: var(--surfaceTxtHintColor, #607d8b);
}

.http-method.head {
    background: var(--surfaceTxtHintColor, #795548);
}

/* Test endpoint button */
.test-endpoint-btn {
    padding: 4px 8px;
    background: var(--successColor);
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 11px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: background-color 0.2s ease;
    margin-left: auto;
}

.test-endpoint-btn:hover {
    background: var(--successColorHover);
}

/* Auth details */
.auth-details {
    background: var(--surfaceAlt1Color);
    border: 1px solid var(--surfaceAlt3Color);
    border-radius: 4px;
    padding: 8px 12px;
}

.auth-icon {
    font-size: 16px;
}

.auth-icon-large {
    font-size: 20px;
}

.auth-type {
    font-size: 11px;
    text-transform: uppercase;
    color: var(--surfaceTxtHintColor);
    font-weight: 500;
}

/* Schema section */
.schema-container {
    background: var(--surfaceAlt1Color);
    border-radius: 4px;
    overflow: hidden;
}

.copy-schema-btn {
    font-size: 11px;
    padding: 2px 6px;
}

/* =============================================================================
   STATISTICS & TABS
   ============================================================================= */

.stats-grid {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 12px;
    background: var(--surfaceAlt1Color);
    border-radius: 4px;
    min-width: 80px;
}

.stat-value {
    font-size: 18px;
    font-weight: 600;
    color: var(--successColor);
}

.stat-label {
    font-size: 11px;
    color: var(--surfaceTxtHintColor);
    text-transform: uppercase;
    margin-top: 2px;
}

/* Main tabs styling */
.tabs-header {
    display: flex;
    border-bottom: 1px solid var(--surfaceAlt3Color);
    background: var(--surfaceAlt1Color);
    padding: 0 16px;
}

.tab-item {
    padding: 12px 16px;
    border: none;
    background: none;
    color: var(--surfaceTxtHintColor);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
}

.tab-item:hover {
    color: var(--surfaceTxtColor);
}

.tab-item.active {
    color: var(--successColor);
    border-bottom-color: var(--successColor);
}

.tabs-content {
    padding: 16px;
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

/* =============================================================================
   LOADING STATES
   (uses .animate-spin / @keyframes spin from dashboard_base_css)
   ============================================================================= */

.api-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    color: var(--surfaceTxtHintColor);
}

.api-loading i {
    margin-right: 8px;
    animation: spin 1s linear infinite;
}

/* =============================================================================
   ALERTS & NOTIFICATIONS
   ============================================================================= */

.alert {
    padding: 12px 16px;
    border-radius: 6px;
    margin-bottom: 16px;
}

.alert-danger {
    background: var(--surfaceDangerColor, rgba(239, 68, 68, 0.1));
    color: var(--dangerColor);
    border: 1px solid var(--dangerColor);
}

.alert i {
    margin-right: 8px;
}

/* =============================================================================
   RESPONSIVE DESIGN
   ============================================================================= */

@media (max-width: 768px) {
    .api-tester-sidebar {
        width: 100%;
        right: -100%;
    }

    .stats-grid {
        justify-content: center;
    }

    .query-param-row {
        flex-direction: column;
        gap: 8px;
    }

    .query-param-name,
    .query-param-value {
        width: 100%;
    }
}

@media (max-width: 480px) {
    .api-endpoint-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
    }

    .test-endpoint-btn {
        align-self: flex-end;
    }
}

/* =============================================================================
   JSON SYNTAX HIGHLIGHTING
   ============================================================================= */

.code-block {
    background: var(--surfaceAlt1Color);
    border: 1px solid var(--surfaceAlt3Color);
    border-radius: 4px;
    overflow: auto;
    max-height: 69vh;
    position: relative;
}

.code-block pre {
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 18px;
    line-height: 1.4;
}

.code-block code {
    background: transparent;
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: inherit;
}

/* JSON syntax colors — light mode defaults */
.json-key {
    color: #1d4ed8;
    font-weight: 600;
}

.json-string {
    color: #dc2626;
    font-weight: 400;
}

.json-number {
    color: #059669;
    font-weight: 500;
}

.json-boolean {
    color: #7c2d12;
    font-weight: 600;
}

.json-null {
    color: #991b1b;
    font-style: italic;
    font-weight: 500;
}

.json-punctuation {
    color: #374151;
    font-weight: 600;
}

/* JSON syntax colors — dark mode overrides */
[data-color-scheme="dark"] .json-key {
    color: #93b5ff;
}

[data-color-scheme="dark"] .json-string {
    color: #ff8a80;
}

[data-color-scheme="dark"] .json-number {
    color: #6ee7b7;
}

[data-color-scheme="dark"] .json-boolean {
    color: #fdba74;
}

[data-color-scheme="dark"] .json-null {
    color: #fca5a5;
}

[data-color-scheme="dark"] .json-punctuation {
    color: #9ca3af;
}

/* Parameter and response styling */
.parameter-item,
.response-item {
    padding: 8px 12px;
    border: 1px solid var(--surfaceAlt3Color);
    border-radius: 4px;
    margin-bottom: 8px;
    background: var(--surfaceColor);
}

.parameter-item code {
    background: var(--surfaceAlt1Color);
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 11px;
}

.response-status {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
}

.http-status {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    color: white;
}

.http-status.status-200,
.http-status.status-201,
.http-status.status-204 {
    background: var(--successColor);
}

.http-status.status-400,
.http-status.status-401,
.http-status.status-403,
.http-status.status-404 {
    background: var(--dangerColor);
}

.http-status.status-500,
.http-status.status-502,
.http-status.status-503 {
    background: var(--warningColor);
}

.response-schema {
    margin-top: 8px;
}

.parameters-list,
.responses-list {
    margin-top: 8px;
}

/* Active filters display */
#active-filters {
    background-color: var(--surfaceAlt1Color);
    border-radius: 6px;
    padding: 6px 12px;
    border: 1px solid var(--surfaceAlt3Color);
}

#active-filters .flex {
    align-items: center;
    min-height: 24px;
}

#filter-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
}

#filter-tags .badge {
    margin: 1px 2px;
}

/* Results summary styling */
#results-summary {
    display: flex;
    align-items: center;
}

/* Clear filters button positioning */
#clear-filters-btn {
    flex-shrink: 0;
    white-space: nowrap;
}

/* Version info styling */
.version-info {
    padding: 8px 16px;
    background: var(--surfaceAlt1Color);
    border: 1px solid var(--surfaceAlt3Color);
    border-radius: 4px;
    margin-bottom: 16px;
}

#version-description {
    font-style: italic;
}

#version-base-url {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 11px;
    background: var(--surfaceAlt3Color);
    padding: 2px 6px;
    border-radius: 3px;
}

</style>

{{template "api_form_css" .}}
{{template "api_sidebar_css" .}}
{{end}}
