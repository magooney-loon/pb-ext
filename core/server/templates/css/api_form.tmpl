{{define "api_form_css"}}
<style>
/* =============================================================================
   API FORM STYLES
   ============================================================================= */

/* =============================================================================
   FORM SECTIONS
   ============================================================================= */

.form-section {
    margin-bottom: 24px;
}

.form-section:last-child {
    margin-bottom: 16px;
}

/* .section-title is defined in dashboard_base_css — not duplicated here */

.section-title i {
    font-size: 16px;
    color: var(--accentColor, var(--primaryColor));
}

.form-section-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--surfaceTxtColor);
    margin: 0 0 8px 0;
    display: flex;
    align-items: center;
    gap: 8px;
}

.form-section-title i {
    color: var(--accentColor, var(--primaryColor));
    font-size: 16px;
}

/* =============================================================================
   QUERY PARAMETERS
   ============================================================================= */

.query-parameters {
    position: relative;
}

.query-param-row {
    display: flex;
    gap: 6px;
    align-items: center;
    margin-bottom: 2px;
}

.query-param-name,
.query-param-value {
    flex: 1;
    min-width: 0;
}

.query-param-name {
    max-width: 140px;
}

.query-param-value {
    max-width: 180px;
}

.add-query-param {
    flex-shrink: 0;
    padding: 6px 8px;
    min-width: 32px;
}

.added-query-params {
    margin-top: 8px;
}

.query-param-added {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 4px 8px;
    background: var(--surfaceAlt1Color, rgba(0,0,0,.04));
    border: 1px solid var(--surfaceAlt3Color, rgba(0,0,0,.1));
    border-radius: 16px;
    margin-right: 6px;
    font-size: 12px;
}

.query-param-added .param-display {
    display: flex;
    align-items: center;
    gap: 4px;
}

.query-param-added .param-name {
    font-weight: 500;
    color: var(--surfaceTxtColor);
}

.query-param-added .param-value {
    color: var(--surfaceTxtHintColor);
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.query-param-added input[name^="query-"] {
    display: none;
}

.remove-query-param {
    flex-shrink: 0;
    padding: 4px;
    border: none;
    background: transparent;
    color: var(--surfaceTxtHintColor);
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s ease;
}

.remove-query-param:hover {
    background: var(--surfaceDangerColor, rgba(212,64,64,.15));
    color: var(--dangerColor, #d44040);
}

/* Query parameter pairs for manual entry */
.query-param-pair {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
}

.query-param-pair:last-child {
    margin-bottom: 0;
}

.query-param-pair input {
    flex: 1;
    min-width: 0;
}

.query-params-container {
    margin-bottom: 16px;
    min-height: 0;
}

.query-params-container:empty {
    margin-bottom: 0;
}

/* =============================================================================
   FORM VALIDATION
   ============================================================================= */

.form-field.required .form-label::after {
    content: ' *';
    color: var(--dangerColor, #d44040);
}

.form-control:invalid {
    border-color: var(--dangerColor, #d44040);
    box-shadow: 0 0 0 3px var(--surfaceDangerColor, rgba(212,64,64,.15));
}

.form-control:valid {
    border-color: var(--successColor, #33b56f);
}

/* =============================================================================
   RESPONSIVE DESIGN
   ============================================================================= */

@media (max-width: 768px) {
    .query-param-row {
        flex-direction: column;
        gap: 8px;
    }

    .query-param-name,
    .query-param-value {
        width: 100%;
        max-width: none;
    }

    .radio-group {
        flex-direction: column;
        gap: 12px;
    }

    .query-param-pair {
        flex-direction: column;
        gap: 8px;
    }

    .query-param-pair input {
        width: 100%;
    }

    .form-section-title {
        font-size: 13px;
    }

    .form-control {
        padding: 8px 10px;
        font-size: 13px;
    }
}

/* .animate-spin and @keyframes spin are defined in dashboard_base_css */
</style>
{{end}}
